# rust runtime
/target

docs/dev/

# IDE files
.vscode/

# external tools (vendored RPCS3, Ghidra, etc.) -- everything under
# tools/ is third-party; CellGov-owned bridges live under bridges/
tools/

# ps3autotests fixture: GPLv2-licensed test corpus from
# https://github.com/AerialX/ps3autotests. Cloned locally by the
# developer; not vendored, so cellgov stays MIT/Apache-2.0. The
# tracked tests/ps3autotests.README.md sibling explains setup.
/tests/ps3autotests/

# test artifacts (compiled ELFs, objects, build output)
tests/micro/**/*.bin
tests/micro/**/*.elf
tests/micro/**/*.self
tests/micro/**/*.o
tests/micro/**/build/
tests/micro/hello_world/

# Raw TTY dumps (binary artifacts from RPCS3 runs)
baselines/**/*.tty

# RPCS3 HLE trace files produced by the cellgov_hle_trace patch
*.htrc

# Large cross-runner observation artifacts (too big for git;
# reproduced from tests/fixtures/*/REPRODUCTION.md)
tests/fixtures/NPUA80001_cross_runner/*.json
tests/fixtures/NPUA80001_cross_runner/*.dump
tests/fixtures/NPUA80068_cross_runner/*.json
tests/fixtures/NPUA80068_cross_runner/*.dump
tests/fixtures/BCES00664_cross_runner/*.json
tests/fixtures/BCES00664_cross_runner/*.dump

# Canonical Sony PS3 libraries extracted from PS3UPDAT.PUP via
# cellgov_firmware. Not for redistribution.
ps3_libs/

# Firmware install destination (per Phase 31 design). cellgov_firmware
# install extracts a user-supplied PS3UPDAT.PUP here; cellgov_cli reads
# encrypted SELFs from firmware/sys/external/ at boot. Bytes are never
# vendored.
firmware/

# AI tooling
.claude/
CLAUDE.local.md

# Python venv, ChromaDB, and local-only ingest scripts
.venv/
.chroma_db/
scripts/
