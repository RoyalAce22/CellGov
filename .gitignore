# rust runtime
/target

docs/dev/

# IDE files
.vscode/

# external tools (vendored RPCS3, Ghidra, etc.) -- everything under
# tools/ is third-party; CellGov-owned bridges live under bridges/
tools/

# ps3autotests fixture: GPLv2-licensed test corpus from
# https://github.com/AerialX/ps3autotests. Cloned locally by the
# developer; not vendored, so cellgov stays MIT/Apache-2.0. The
# tracked tests/ps3autotests.README.md sibling explains setup.
/tests/ps3autotests/

# test artifacts (compiled ELFs, objects, build output)
tests/micro/**/*.bin
tests/micro/**/*.elf
tests/micro/**/*.self
tests/micro/**/*.o
tests/micro/**/build/
tests/micro/hello_world/

# Raw TTY dumps (binary artifacts from RPCS3 runs)
baselines/**/*.tty

# RPCS3 HLE trace files produced by the cellgov_hle_trace patch
*.htrc

# Large cross-runner observation artifacts (too big for git;
# reproduced from tests/fixtures/<id>/cross_runner/REPRODUCTION.md).
# Per-runner observations live under tests/fixtures/<id>/<runner>/.
tests/fixtures/*/cellgov/observation.json
tests/fixtures/*/cellgov/observation_*.json
tests/fixtures/*/rpcs3/observation.json
tests/fixtures/*/rpcs3/observation_*.json
tests/fixtures/*/rpcs3/*.dump

# Firmware install destination. cellgov_firmware install extracts a
# user-supplied PS3UPDAT.PUP here; cellgov_cli reads encrypted SELFs
# from firmware/sys/external/ at boot. Bytes are never vendored.
firmware/

# AI tooling
.claude/
CLAUDE.local.md

# Python venv, ChromaDB, and local-only ingest scripts
.venv/
.chroma_db/
scripts/

# Local investigation dumps: hle_watch / value_sample / store_watch
# binary captures + ad-hoc parse helpers. Regenerable via the
# env-gated diagnostics; never vendored.
scratch/
