# Normalize all text files to LF in the repository.
# Working-tree line endings on Windows still follow core.autocrlf,
# but the stored copy is always LF so CI and cross-platform diffs stay clean.
* text=auto eol=lf

# Count microtest C sources in language stats.
tests/micro/**/*.c linguist-vendored=false

# ps3autotests `.expected` files are real-PS3 TTY captures; their
# bytes (including any embedded \r) must round-trip exactly. Force
# them as binary so autocrlf cannot rewrite \n to \r\n on Windows
# checkouts. Applies only if anyone ever vendors the corpus; the
# directory is otherwise gitignored.
tests/ps3autotests/**/*.expected -text
tests/ps3autotests/**/*.elf -text
